{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Launch main.js (Run)",
      "type": "pwa-node",
      "request": "launch",
      "program": "${workspaceFolder}/main.js",
      "cwd": "${workspaceFolder}",
      "runtimeArgs": ["--enable-source-maps"],
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen"
    },
    {
      "name": "Attach to Node",
      "type": "pwa-node",
      "request": "attach",
      "port": 9229,
      "restart": false,
      "localRoot": "${workspaceFolder}",
      "remoteRoot": "${workspaceFolder}"
    }
  ]
}
